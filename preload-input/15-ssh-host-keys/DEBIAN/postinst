#!/bin/sh
# DopamineX preload: ensure sshd host keys exist after openssh-server is installed.
#
# Why this exists:
#   openssh-server's own postinst runs ssh-keygen -A on FIRST install only.
#   Dopamine reinstalls openssh-server via 'dpkg -i' on every activation
#   (preinstalledDebs loop), and dpkg -i on an already-installed-same-version
#   package does NOT rerun postinst. So if the very first activation failed
#   midway (before openssh-server postinst could run keygen), all subsequent
#   activations silently skip key generation.
#
#   Symptom: ssh client sees "kex_exchange_identification: Connection closed
#   by remote host" -- sshd accepts TCP but the worker process exits before
#   sending its banner because it can't load any host key.
#
# What this does:
#   1. Generate each missing host key (rsa / ecdsa / ed25519) idempotently
#   2. Kickstart sshd via launchctl so a running instance picks up new keys
#
# Safe to re-run on every activation; pre-existing keys are not regenerated.

set -e

JB=/var/jb
SSH_DIR="$JB/etc/ssh"
KEYGEN="$JB/usr/bin/ssh-keygen"

# Sanity: openssh-client must have installed ssh-keygen before us
if [ ! -x "$KEYGEN" ]; then
    echo "DopamineX/15-ssh-host-keys: $KEYGEN not found; openssh-client missing?" >&2
    exit 0   # not fatal: skip gracefully so preload loop continues
fi

mkdir -p "$SSH_DIR"
chmod 0755 "$SSH_DIR"

generated=0
for t in rsa ecdsa ed25519; do
    keyfile="$SSH_DIR/ssh_host_${t}_key"
    if [ ! -f "$keyfile" ]; then
        echo "DopamineX/15-ssh-host-keys: generating $keyfile" >&2
        "$KEYGEN" -q -t "$t" -N "" -f "$keyfile"
        chmod 0600 "$keyfile"
        chmod 0644 "${keyfile}.pub"
        generated=$((generated + 1))
    fi
done

# Bootstrap or restart sshd:
#   1. If launchd has the daemon registered  → kickstart (restart with new key)
#   2. If launchd has NOT registered it yet   → bootstrap (load plist from disk)
#
# Background: Dopamine's jbctl startup runs
#   launchctl bootstrap system /Library/LaunchDaemons
# but if that step never executes (e.g. first activation aborts midway),
# sshd's plist sits on disk unloaded -- ssh client sees Connection reset
# because nothing listens on the configured port. This makes the 15-host-keys
# package self-sufficient: it guarantees sshd is running before exiting postinst.

echo "DopamineX/15-ssh-host-keys: ensuring sshd is running" >&2

LAUNCHCTL="$JB/bin/launchctl"
[ -x "$LAUNCHCTL" ] || LAUNCHCTL="$(command -v launchctl || true)"

SSHD_LABEL="com.openssh.sshd"
SSHD_PLIST="/var/jb/Library/LaunchDaemons/${SSHD_LABEL}.plist"

if [ -n "$LAUNCHCTL" ] && [ -f "$SSHD_PLIST" ]; then
    # 1. 是否已注册到 system domain?
    if "$LAUNCHCTL" print "system/${SSHD_LABEL}" >/dev/null 2>&1; then
        # 已注册 — 仅当新生成了 key 时才需重启
        if [ "$generated" -gt 0 ]; then
            echo "DopamineX/15-ssh-host-keys: kickstart sshd (existing daemon, ${generated} new key)" >&2
            "$LAUNCHCTL" kickstart -k "system/${SSHD_LABEL}" 2>&1 || true
        fi
    else
        # 未注册 — bootstrap 加载
        echo "DopamineX/15-ssh-host-keys: sshd not loaded; bootstrapping ${SSHD_PLIST}" >&2
        "$LAUNCHCTL" bootstrap system "$SSHD_PLIST" 2>&1 || \
            echo "DopamineX/15-ssh-host-keys: WARN bootstrap failed (non-fatal, continuing)" >&2
    fi
else
    echo "DopamineX/15-ssh-host-keys: WARN launchctl or sshd plist missing; skipping daemon mgmt" >&2
fi

if [ "$generated" -eq 0 ]; then
    echo "DopamineX/15-ssh-host-keys: all host keys already present" >&2
fi

exit 0
