diff --git a/Application/Dopamine/Exploits/palera1n/Makefile b/Application/Dopamine/Exploits/palera1n/Makefile
index f16211f..d08ce4b 100644
--- a/Application/Dopamine/Exploits/palera1n/Makefile
+++ b/Application/Dopamine/Exploits/palera1n/Makefile
@@ -12,7 +12,11 @@ LIBRARY_NAME = palera1n
 
 palera1n_FILES = palera1n.m
 palera1n_CFLAGS = -fobjc-arc -I../../../../BaseBin/.include
-palera1n_LDFLAGS = -L../../../../BaseBin/.build -ljailbreak
+# -not_for_dyld_shared_cache: Xcode 26 的新链接器会把装到 /usr/lib 的 dylib 标为
+# "shared-cache eligible"，而它链接的 libjailbreak.dylib 是 @loader_path 的(ineligible)，
+# 新 ld 会报 "eligible dylib cannot link to ineligible dylib"。palera1n 是运行时注入的
+# 越狱 dylib，本就不该进 dyld 共享缓存，显式 opt-out 即可（旧链接器忽略该 flag，无副作用）。
+palera1n_LDFLAGS = -L../../../../BaseBin/.build -ljailbreak -Wl,-not_for_dyld_shared_cache
 palera1n_INSTALL_PATH = /usr/lib
 
 include $(THEOS_MAKE_PATH)/library.mk
diff --git a/BaseBin/roothidehooks/cfprefsd.x b/BaseBin/roothidehooks/cfprefsd.x
index e169b01..0e504d6 100644
--- a/BaseBin/roothidehooks/cfprefsd.x
+++ b/BaseBin/roothidehooks/cfprefsd.x
@@ -1,8 +1,23 @@
 #import <Foundation/Foundation.h>
 #import <substrate.h>
 #include <roothide.h>
+#include <dlfcn.h>
 #include "common.h"
 
+// xpc_connection_get_pid 在 iOS 18.5/26 SDK 的头文件里被标 unavailable（声明被删/加了
+// __API_UNAVAILABLE），导致用新版 Xcode 直接引用编不过。但该符号在运行时 libxpc 里一直
+// 存在，roothide 目标系统(iOS<=16.5)上完全可用。这里用 dlsym 在运行时取，绕开头文件声明，
+// 让任意 Xcode（含 26）都能本地编过。仅用于取 client pid 打日志。
+static pid_t roothide_xpc_connection_get_pid(xpc_connection_t connection)
+{
+	static pid_t (*fn)(xpc_connection_t) = NULL;
+	static dispatch_once_t onceToken;
+	dispatch_once(&onceToken, ^{
+		fn = (pid_t (*)(xpc_connection_t))dlsym(RTLD_DEFAULT, "xpc_connection_get_pid");
+	});
+	return fn ? fn(connection) : -1;
+}
+
 #define PROC_PIDPATHINFO_MAXSIZE        (4*MAXPATHLEN)
 
 pid_t __thread gCurrentClientPid = 0;
